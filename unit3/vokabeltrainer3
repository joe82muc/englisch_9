<style>
  :root {
    --bg: #f7f3ee;
    --card: #fff;
    --klett-blue: #1a4a8a;
    --klett-red: #c0392b;
    --mint: #27ae60;
    --text: #1a1a2e;
    --muted: #7f8c8d;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(26,74,138,0.10);
    --safe-top: env(safe-area-inset-top, 0px);
    --safe-bottom: env(safe-area-inset-bottom, 0px);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body {
    font-family: 'Nunito', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    min-height: -webkit-fill-available;
    padding: calc(var(--safe-top) + 1.5rem) 1rem calc(var(--safe-bottom) + 3rem);
    -webkit-text-size-adjust: 100%;
  }

  /* Install Banner */
  #install-banner {
    display: none;
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: var(--klett-blue); color: #fff;
    padding: calc(var(--safe-top) + 0.8rem) 1rem 0.8rem;
    font-size: 0.82rem; font-weight: 600;
    flex-direction: column; gap: 0.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  }
  #install-banner.show { display: flex; }
  .banner-row { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .banner-steps { font-size: 0.75rem; opacity: 0.85; line-height: 1.5; }
  .banner-steps span { display: block; }
  #close-banner {
    background: rgba(255,255,255,0.2); border: none; color: #fff;
    border-radius: 50%; width: 28px; height: 28px; font-size: 1rem;
    cursor: pointer; flex-shrink: 0; display: flex; align-items: center; justify-content: center;
  }

  /* Header */
  .header { text-align: center; margin-bottom: 1.4rem; }
  .klett-badge {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: var(--klett-blue); color: #fff;
    padding: 0.3rem 0.9rem; border-radius: 50px;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 1px;
    margin-bottom: 0.6rem; text-transform: uppercase;
  }
  h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.5rem, 5vw, 2.2rem);
    font-weight: 900; color: var(--klett-blue); line-height: 1.1;
  }
  .subtitle { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }

  /* Offline badge */
  #offline-badge {
    display: none; text-align: center; margin-bottom: 0.5rem;
    font-size: 0.75rem; color: var(--klett-red); font-weight: 700;
  }

  /* Controls */
  .controls { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; margin-bottom: 1.2rem; }
  .pill-group { display: flex; background: #e8e0d8; border-radius: 50px; padding: 3px; }
  .pill {
    padding: 0.4rem 0.9rem; border: none; border-radius: 50px; cursor: pointer;
    font-family: 'Nunito', sans-serif; font-size: 0.82rem; font-weight: 600;
    background: transparent; color: var(--muted); transition: all 0.2s; white-space: nowrap;
  }
  .pill.active { background: var(--klett-blue); color: #fff; }

  /* Score */
  .scorebar { display: flex; justify-content: center; gap: 2rem; margin-bottom: 1rem; font-size: 0.82rem; color: var(--muted); }
  .scorebar span { display: flex; flex-direction: column; align-items: center; gap: 1px; }
  .scorebar strong { font-size: 1.4rem; color: var(--text); font-family: 'Playfair Display', serif; }

  /* Progress */
  .progress-wrap { max-width: 500px; margin: 0 auto 1.2rem; background: #ddd5c8; height: 6px; border-radius: 3px; overflow: hidden; }
  .progress-bar { height: 100%; background: var(--klett-blue); border-radius: 3px; transition: width 0.4s; }

  /* Filter */
  .filter-row { display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center; margin-bottom: 0.7rem; }
  .filter-btn {
    padding: 0.28rem 0.7rem; border: 2px solid #ddd; border-radius: 50px;
    background: transparent; font-family: 'Nunito', sans-serif; font-size: 0.75rem;
    font-weight: 600; color: var(--muted); cursor: pointer; transition: all 0.2s;
  }
  .filter-btn.active { border-color: var(--klett-blue); color: var(--klett-blue); background: #e8f0fc; }

  /* Card */
  .card {
    background: var(--card); border-radius: var(--radius);
    padding: 1.8rem 1.4rem 1.5rem; max-width: 500px; margin: 0 auto;
    box-shadow: var(--shadow); border-top: 5px solid var(--klett-blue); position: relative;
  }
  .unit-tag {
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    background: var(--klett-red); color: #fff;
    font-size: 0.65rem; font-weight: 700; letter-spacing: 1px;
    padding: 2px 10px; border-radius: 0 0 8px 8px; text-transform: uppercase;
  }
  .direction-label { text-align: center; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; color: var(--muted); margin-bottom: 1.1rem; }
  .question-word {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 5.5vw, 2.6rem);
    font-weight: 700; text-align: center; color: var(--klett-blue); line-height: 1.2; margin-bottom: 0.3rem;
  }
  .phonetic { text-align: center; color: var(--muted); font-size: 0.85rem; margin-bottom: 0.4rem; font-style: italic; }
  .speak-btn {
    display: block; margin: 0 auto 1.3rem;
    background: none; border: 1.5px solid #ddd; border-radius: 50px;
    padding: 0.32rem 1rem; cursor: pointer; font-size: 0.78rem; color: var(--muted);
    font-family: 'Nunito', sans-serif; transition: all 0.2s;
    -webkit-appearance: none;
  }
  .speak-btn.speak-highlight {
    border-color: var(--mint); color: var(--mint);
    background: #eafaf1; font-size: 0.9rem; padding: 0.5rem 1.3rem;
    animation: speakpop 0.3s ease;
  }
  @keyframes speakpop {
    from { transform: scale(0.9); opacity: 0; }
    to   { transform: scale(1);   opacity: 1; }
  }

  /* Choices */
  .choices { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
  .choice {
    padding: 0.8rem 0.5rem; background: #f0ebe4; border: 2px solid transparent;
    border-radius: 12px; color: var(--text); font-family: 'Nunito', sans-serif;
    font-size: 0.88rem; font-weight: 600; cursor: pointer; text-align: center;
    transition: all 0.15s; line-height: 1.3; -webkit-appearance: none;
  }
  .choice:active:not(:disabled) { transform: scale(0.97); }
  .choice.correct { border-color: var(--mint); background: #eafaf1; color: var(--mint); }
  .choice.wrong   { border-color: var(--klett-red); background: #fdf0ef; color: var(--klett-red); }
  .choice:disabled { cursor: default; }

  /* Typing */
  .type-area { display: flex; flex-direction: column; gap: 0.6rem; }
  .type-area input {
    width: 100%; padding: 0.85rem 1rem; border: 2px solid #ddd; border-radius: 12px;
    font-family: 'Nunito', sans-serif; font-size: 1rem; font-weight: 600;
    color: var(--text); background: #f9f6f2; outline: none; transition: border 0.2s;
    -webkit-appearance: none;
  }
  .type-area input:focus { border-color: var(--klett-blue); }
  .type-area input.correct { border-color: var(--mint); background: #eafaf1; }
  .type-area input.wrong   { border-color: var(--klett-red); background: #fdf0ef; }

  /* Feedback */
  .feedback { text-align: center; min-height: 1.4rem; font-size: 0.9rem; font-weight: 700; margin-top: 0.9rem; }
  .feedback.good { color: var(--mint); }
  .feedback.bad  { color: var(--klett-red); }

  /* Buttons */
  .btn-row { display: flex; gap: 0.6rem; margin-top: 1rem; justify-content: center; }
  .btn-primary {
    padding: 0.7rem 1.8rem; background: var(--klett-blue); color: #fff;
    border: none; border-radius: 50px; font-family: 'Nunito', sans-serif;
    font-size: 0.92rem; font-weight: 700; cursor: pointer; -webkit-appearance: none;
    transition: all 0.2s;
  }
  .btn-primary:active { transform: scale(0.97); }
  .btn-secondary {
    padding: 0.7rem 1.3rem; background: transparent; color: var(--muted);
    border: 2px solid #ddd; border-radius: 50px; font-family: 'Nunito', sans-serif;
    font-size: 0.88rem; cursor: pointer; -webkit-appearance: none;
  }

  /* Result */
  #result { display: none; text-align: center; max-width: 500px; margin: 0 auto; padding: 2rem 1rem; }
  #result h2 { font-family: 'Playfair Display', serif; font-size: 2rem; margin-bottom: 0.4rem; color: var(--klett-blue); }
  .big-pct { font-family: 'Playfair Display', serif; font-size: 4.5rem; font-weight: 900; color: var(--klett-red); }

  @keyframes pop { from{transform:scale(0.93);opacity:0} to{transform:scale(1);opacity:1} }
  .card { animation: pop 0.25s ease; }
</style>
</head>
