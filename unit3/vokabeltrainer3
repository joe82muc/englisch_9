  {en:"monkey",de:"Affe",pron:"ˈmʌŋki",topic:"mediation"},
  {en:"state",de:"Landes-; staatlich",pron:"steɪt",topic:"more"},
  {en:"function",de:"Funktion",pron:"ˈfʌŋkʃən",topic:"more"},
  {en:"to sink",de:"untergehen; sinken",pron:"sɪŋk",topic:"more"},
  {en:"lighthouse",de:"Leuchtturm",pron:"ˈlaɪthaʊs",topic:"more"},
  {en:"arch",de:"Bogen",pron:"ɑːtʃ",topic:"more"},
  {en:"viewing platform",de:"Aussichtsplattform",pron:"ˈvjuːɪŋ ˌplætfɔːm",topic:"more"},
  {en:"speech",de:"Rede; Vortrag; Sprache",pron:"spiːtʃ",topic:"more"},
  {en:"region",de:"Region; Gegend",pron:"ˈriːdʒən",topic:"more"},
  {en:"game reserve",de:"Wildreservat; Wildschutzgebiet",pron:"ɡeɪm rɪˈzɜːv",topic:"more"},
  {en:"lion",de:"Löwe",pron:"ˈlaɪən",topic:"more"},
  {en:"leopard",de:"Leopard",pron:"ˈlepəd",topic:"more"},
  {en:"rhino",de:"Rhinozeros; Nashorn",pron:"ˈraɪnəʊ",topic:"more"},
  {en:"extinction",de:"Aussterben",pron:"ɪkˈstɪŋkʃən",topic:"more"},
  {en:"bushman",de:"Buschmann",pron:"ˈbʊʃmən",topic:"more"},
  {en:"redbush",de:"Roibusch",pron:"ˈredbʊʃ",topic:"more"},
];

// ── STATE ──────────────────────────────────────────────────────────────────
let mode='mc', dirSetting='random', filterTopic='all';
let queue=[], current=null, right=0, wrong=0;
let direction='en-de', answered=false;
let speakWord='', speakLang='en-GB';

const shuffle = a => [...a].sort(()=>Math.random()-0.5);
const filteredVocab = () => filterTopic==='all' ? vocab : vocab.filter(v=>v.topic===filterTopic);

// ── INSTALL BANNER (iPhone) ────────────────────────────────────────────────
function isIOS() {
  return /iphone|ipad|ipod/i.test(navigator.userAgent);
}
function isStandalone() {
  return window.navigator.standalone === true;
}
function closeBanner() {
  document.getElementById('install-banner').classList.remove('show');
  localStorage.setItem('install-dismissed','1');
}
window.addEventListener('load', () => {
  if (isIOS() && !isStandalone() && !localStorage.getItem('install-dismissed')) {
    setTimeout(() => document.getElementById('install-banner').classList.add('show'), 1500);
  }
});

// ── OFFLINE DETECTION ──────────────────────────────────────────────────────
window.addEventListener('online',  () => document.getElementById('offline-badge').style.display='none');
window.addEventListener('offline', () => document.getElementById('offline-badge').style.display='block');

// ── SERVICE WORKER (Offline-Cache) ────────────────────────────────────────
if ('serviceWorker' in navigator) {
  const swCode = `
    const CACHE = 'vokabel-v1';
    const ASSETS = [self.location.href];
    self.addEventListener('install', e => {
      e.waitUntil(caches.open(CACHE).then(c => c.addAll(ASSETS)));
      self.skipWaiting();
    });
    self.addEventListener('activate', e => {
      e.waitUntil(caches.keys().then(keys =>
        Promise.all(keys.filter(k=>k!==CACHE).map(k=>caches.delete(k)))
      ));
    });
    self.addEventListener('fetch', e => {
      e.respondWith(
        caches.match(e.request).then(r => r || fetch(e.request).catch(() => caches.match(e.request)))
      );
    });
  `;
  const swBlob = new Blob([swCode], {type:'application/javascript'});
  const swUrl  = URL.createObjectURL(swBlob);
  navigator.serviceWorker.register(swUrl).catch(()=>{});
}

// ── CONTROLS ──────────────────────────────────────────────────────────────
function setMode(m, btn) {
  mode = m;
  document.querySelectorAll('.pill').forEach(b => {
    if (b.textContent.includes('Choice')||b.textContent.includes('Tippen')) b.classList.remove('active');
  });
  btn.classList.add('active');
  document.getElementById('mc-area').style.display   = m==='mc'   ? 'block' : 'none';
  document.getElementById('type-area').style.display = m==='type' ? 'block' : 'none';
  restart();
}
function setDir(d, btn) {
  dirSetting = d;
  document.querySelectorAll('.pill').forEach(b => {
    if (b.textContent.includes('→')||b.textContent.includes('Zufällig')) b.classList.remove('active');
  });
  btn.classList.add('active');
  restart();
}
function setFilter(f, btn) {
  filterTopic = f;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  restart();
}

// ── CORE ──────────────────────────────────────────────────────────────────
function restart() {
  right=0; wrong=0; updateScore();
  queue = shuffle(filteredVocab());
  document.getElementById('result').style.display    = 'none';
  document.getElementById('quiz-card').style.display = 'block';
  document.querySelector('.progress-wrap').style.display = 'block';
  nextCard();
}

function nextCard() {
  if (queue.length===0) { showResult(); return; }
  current = queue.pop();
  answered = false;

  direction = dirSetting==='random' ? (Math.random()>0.5 ? 'en-de' : 'de-en') : dirSetting;
  const isEnDe = direction==='en-de';
  const qWord = isEnDe ? current.en : current.de;
  const aWord = isEnDe ? current.de : current.en;

  document.getElementById('dir-label').textContent = isEnDe ? '🇬🇧 Englisch → 🇩🇪 Deutsch' : '🇩🇪 Deutsch → 🇬🇧 Englisch';
  document.getElementById('qword').textContent     = qWord;
  document.getElementById('phonetic').textContent  = isEnDe ? '['+current.pron+']' : '';
  document.getElementById('feedback').textContent  = '';
  document.getElementById('feedback').className    = 'feedback';
  document.getElementById('skip-btn').style.display = '';
  document.getElementById('next-btn').style.display = 'none';

  // Speak button always shows the English word
  speakWord = current.en;
  speakLang = 'en-GB';
  const sBtn = document.getElementById('speak-btn');
  sBtn.textContent = '🔊 anhören';
  sBtn.className = 'speak-btn';  // reset highlight

  const tags = {intro:'Intro',topic1:'Topic 1',topic2:'Topic 2',text:'Text',mediation:'Mediation',more:'More About'};
  document.getElementById('unit-tag').textContent = tags[current.topic]||'Unit 3';

  updateProgress();
  if (mode==='mc') buildChoices(aWord, isEnDe);
  else {
    const inp = document.getElementById('type-input');
    inp.value=''; inp.className=''; inp.disabled=false;
    const hBtn = document.getElementById('hint-btn');
    if (hBtn) hBtn.disabled = false;
    setTimeout(()=>inp.focus(), 100);
  }
}

function buildChoices(correct, isEnDe) {
  const pool = shuffle(filteredVocab().filter(v=>v!==current)).slice(0,3);
  const opts = shuffle([correct, ...pool.map(v=>isEnDe?v.de:v.en)]);
  const cont = document.getElementById('choices');
  cont.innerHTML='';
  opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className='choice'; btn.textContent=opt;
    btn.onclick = ()=>checkChoice(btn,opt,correct);
    cont.appendChild(btn);
  });
}

function checkChoice(btn, chosen, correct) {
  if (answered) return;
  answered=true;
  document.querySelectorAll('.choice').forEach(b=>{
    b.disabled=true;
    if(b.textContent===correct) b.classList.add('correct');
  });
  const sBtn = document.getElementById('speak-btn');
  sBtn.textContent = '🔊 ' + current.en + ' anhören';
  sBtn.className = 'speak-btn speak-highlight';
  if (chosen===correct) {
    btn.classList.add('correct');
    showFeedback(true);
    right++;
    speak();
  } else {
    btn.classList.add('wrong');
    showFeedback(false, correct);
    wrong++;
  }
  updateScore();
  showNextBtn();
}

function showHint() {
  if (answered) return;
  const correct = direction==='en-de' ? current.de : current.en;
  const first = correct.split(';')[0].trim();
  const inp = document.getElementById('type-input');
  // Show one more letter each time hint is pressed
  const currentVal = inp.value;
  const nextLen = currentVal.length + 1;
  inp.value = first.substring(0, nextLen);
  inp.focus();
  // Disable hint when full word revealed
  if (nextLen >= first.length) {
    document.getElementById('hint-btn').disabled = true;
  }
}

function checkType() {
  if (answered) return;
  const inp = document.getElementById('type-input');
  const val = inp.value.trim();
  const correct = direction==='en-de' ? current.de : current.en;
  // Strip "to " for comparison (works in both directions)
  const norm = s => s.trim().toLowerCase().replace(/^to\s+/, '');
  const variants = correct.split(/[;,]/).map(norm).filter(Boolean);
  const ok = variants.some(v => norm(val) === v);
  answered=true; inp.disabled=true;
  document.getElementById('hint-btn').disabled = true;
  const sBtn = document.getElementById('speak-btn');
  sBtn.textContent = '🔊 ' + current.en + ' anhören';
  sBtn.className = 'speak-btn speak-highlight';
  if (ok) {
    inp.classList.add('correct'); showFeedback(true); right++;
    speak();
  } else {
    inp.classList.add('wrong'); showFeedback(false, correct); wrong++;
  }
  updateScore();
  showNextBtn();
}

function showNextBtn() {
  document.getElementById('skip-btn').style.display = 'none';
  document.getElementById('next-btn').style.display = '';
}

function skip() {
  if (answered) return;
  answered = true;
  const correct = direction==='en-de' ? current.de : current.en;
  showFeedback(false, correct);
  wrong++; updateScore();
  showNextBtn();
}

function showFeedback(ok, correct) {
  const el = document.getElementById('feedback');
  el.className = 'feedback '+(ok?'good':'bad');
  el.textContent = ok ? '✅ Richtig! Super!' : '❌ Falsch! Richtig: '+correct;
}

function speak() {
  if (!current) return;
  const u = new SpeechSynthesisUtterance(current.en);
  u.lang='en-GB'; u.rate=0.85;
  speechSynthesis.cancel();
  speechSynthesis.speak(u);
}

function updateScore() {
  document.getElementById('sc-right').textContent = right;
  document.getElementById('sc-wrong').textContent = wrong;
  document.getElementById('sc-total').textContent = right+wrong;
}
function updateProgress() {
  const total = filteredVocab().length;
  document.getElementById('pbar').style.width = ((total-queue.length)/total*100)+'%';
}
function showResult() {
  document.getElementById('quiz-card').style.display='none';
  document.querySelector('.progress-wrap').style.display='none';
  const pct = Math.round(right/(right+wrong)*100)||0;
  document.getElementById('pct-display').textContent=pct+'%';
  document.getElementById('result').style.display='block';
}

restart();
</script>
</body>
</html>
